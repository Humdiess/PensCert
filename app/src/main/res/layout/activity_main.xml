<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Fragment Container -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        android:clipChildren="false"
        android:clipToPadding="false"/>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:layout_gravity="bottom"
        android:background="@color/nav_bar_bg"
        android:elevation="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <!-- Home -->
        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navHomeIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                app:tint="@color/nav_active_icon" />

            <TextView
                android:id="@+id/navHomeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="sans-serif-medium"
                android:text="Home"
                android:textColor="@color/nav_active_icon"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Documents -->
        <LinearLayout
            android:id="@+id/navDocs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navDocsIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_document"
                app:tint="@color/nav_inactive" />

            <TextView
                android:id="@+id/navDocsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="sans-serif-medium"
                android:text="Dokumen"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- QR Scan Button (sejajar dengan nav items) -->
        <FrameLayout
            android:layout_width="84dp"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/fabScan"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_qr_nav_button"
                android:contentDescription="Scan QR"
                android:padding="14dp"
                android:src="@drawable/ic_qr_scan"
                app:tint="@android:color/white"
                android:clickable="true"
                android:focusable="true" />
        </FrameLayout>

        <!-- Notification -->
        <LinearLayout
            android:id="@+id/navNotif"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navNotifIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_notification"
                app:tint="@color/nav_inactive" />

            <TextView
                android:id="@+id/navNotifLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="sans-serif-medium"
                android:text="Notifikasi"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- Profile -->
        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/navProfileIcon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/nav_inactive" />

            <TextView
                android:id="@+id/navProfileLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="sans-serif-medium"
                android:text="Profil"
                android:textColor="@color/nav_inactive"
                android:textSize="10sp" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
