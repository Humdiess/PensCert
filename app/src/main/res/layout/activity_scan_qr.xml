<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1E">

    <!-- Camera Preview -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/zxing_barcode_scanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:zxing_preview_scaling_strategy="centerCrop"
        app:zxing_use_texture_view="true" />

    <!-- Gradient Overlay — top dark fade -->
    <View
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/gradient_top_dark"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Gradient Overlay — bottom dark fade -->
    <View
        android:layout_width="match_parent"
        android:layout_height="260dp"
        android:background="@drawable/gradient_bottom_dark"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Subtle full-screen dim -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#40000000" />

    <!-- Header Group -->
    <LinearLayout
        android:id="@+id/header_group"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="76dp"
        android:layout_marginEnd="72dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Brand chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_brand_chip"
            android:gravity="center_vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/dot_active"
                android:backgroundTint="#66CFF6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.14"
                android:text="PENS CERT"
                android:textColor="#66CFF6"
                android:textSize="10sp"
                android:fontFamily="sans-serif-bold" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Pindai Dokumen"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Arahkan kamera ke kode QR pada sertifikat"
            android:textColor="#99FFFFFF"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <!-- Close Button — larger tap target, clear icon -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginTop="76dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_close_button"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:scaleType="centerInside"
        android:padding="10dp"
        android:contentDescription="Tutup scanner"
        android:elevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#FFFFFF" />

    <!-- Scanner Frame with premium corners -->
    <FrameLayout
        android:id="@+id/scanner_container"
        android:layout_width="260dp"
        android:layout_height="260dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.46">

        <!-- Subtle inner glow background -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_scanner_inner_glow" />

        <!-- Custom corner brackets -->
        <com.example.penscert.ScannerCornersView
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Scanning line -->
        <View
            android:id="@+id/scan_line"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="@drawable/bg_scan_line" />
    </FrameLayout>

    <!-- Status Pill — premium glass effect -->
    <LinearLayout
        android:id="@+id/status_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_status_pill"
        android:gravity="center"
        android:paddingHorizontal="18dp"
        android:paddingVertical="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scanner_container">

        <View
            android:id="@+id/status_dot"
            android:layout_width="7dp"
            android:layout_height="7dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/dot_active"
            android:backgroundTint="#66CFF6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mencari Kode QR..."
            android:textColor="#E0FFFFFF"
            android:textSize="12sp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02" />
    </LinearLayout>

    <!-- Hint text below status pill -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Pastikan kode QR terlihat jelas dan tidak buram"
        android:textColor="#60FFFFFF"
        android:textSize="11sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/status_pill" />

    <!-- Bottom Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp"
        android:paddingHorizontal="24dp"
        android:weightSum="3"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/btn_flash"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tool_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#66CFF6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Flash"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_gallery"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tool_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="#66CFF6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Galeri"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_focus"
            android:layout_width="0dp"
            android:layout_height="74dp"
            android:layout_weight="1"
            android:background="@drawable/bg_tool_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#66CFF6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Fokus"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
